# Copy to .env and edit before running.

# Directory containing *.log files to monitor (all .log files are auto-discovered)
LOG_DIR=/var/log/apache2

# For testing without Apache:
# LOG_DIR=/tmp/testlogs

# LLM integration — disabled by default
LLM_ENABLED=false
AMD_SUBSCRIPTION_KEY=
LLM_MODEL=GPT-oss-20B
LLM_CHUNK_SIZE=20

# Remote agent authentication (agents must send this key in X-Agent-Key header)
AGENT_SECRET=changeme

# Flask
SECRET_KEY=change-me-in-production
FLASK_ENV=development
