# Copy to .env and edit before running.

# Directory containing *.log files to monitor (all .log files are auto-discovered)
LOG_DIR=/var/log/apache2

# For testing without Apache:
# LOG_DIR=/tmp/testlogs

# LLM integration — disabled by default
LLM_ENABLED=false
ANTHROPIC_API_KEY=
LLM_MODEL=claude-3-5-haiku-20241022
LLM_CHUNK_SIZE=20

# Flask
SECRET_KEY=change-me-in-production
FLASK_ENV=development
